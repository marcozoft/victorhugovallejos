RewriteEngine On
RewriteBase /publicaciones/memorias-geograficas/fotos/

# If request is an existing file or directory, serve it directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route everything else to index.php?slug=<slug>
# Matches: /publicaciones/memorias-geograficas/fotos/some-slug
# Matches: /publicaciones/memorias-geograficas/fotos/some-slug/
RewriteRule ^([a-z0-9-]+)/?$ index.php?slug=$1 [L,QSA]
